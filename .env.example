# Supabase (Auth + Postgres). Copy to .env.local for local dev; add the same in Vercel → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: canonical public URL for email magic links (Vercel sets VERCEL_URL automatically)
# SITE_URL=https://your-project.vercel.app

# Chat uses a built-in local Sakhi engine (no external AI API keys).

# Supabase (Auth + Postgres). Copy to .env.local for local dev; add the same in Vercel → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini — server only (never use NEXT_PUBLIC_). Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: if the default model errors, try gemini-1.5-flash or gemini-2.5-flash-preview-05-20 (names change over time)
# GEMINI_MODEL=gemini-2.0-flash

# Supabase (Auth + Postgres). Copy to .env.local for local dev; add the same in Vercel → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: canonical public URL for email magic links (Vercel sets VERCEL_URL automatically)
# SITE_URL=https://your-project.vercel.app

# Google Gemini — server only (never use NEXT_PUBLIC_). Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: the API tries gemini-2.0-flash, then gemini-1.5-flash, then a preview id. Override if your key only supports one id (see Google AI Studio → model list):
# GEMINI_MODEL=gemini-2.0-flash

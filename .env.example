# Supabase (Auth + Postgres). Copy to .env.local for local dev; add the same in Vercel → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini — server only (never use NEXT_PUBLIC_). Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Default in code is gemini-1.5-flash (faster; helps on Vercel Hobby ~10s limit). Override if needed:
# GEMINI_MODEL=gemini-2.0-flash
